# Porta do servidor (Render define PORT automaticamente)
PORT=10000

# Host (0.0.0.0 para aceitar conexões externas)
HOST=0.0.0.0

# Ambiente
NODE_ENV=development

# Caminho do banco SQLite
DB_PATH=./db.sqlite3

# Origens CORS (separadas por vírgula)
# CORS_ORIGIN=http://localhost:5173,https://site-psi.vercel.app

# JWT (obrigatório em produção)
# JWT_SECRET=seu-segredo-forte-aqui

# Credenciais do primeiro admin (apenas para seed)
# ADMIN_EMAIL=admin@sitepsicologia.com
# ADMIN_PASSWORD=admin123
